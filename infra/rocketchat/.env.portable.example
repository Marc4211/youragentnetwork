# Portable env for Agent Network. Copy to .env (gitignored) and fill in,
# then run:  bash scripts/install.sh
#
#   cp .env.portable.example .env
#
# No LLM key here on purpose: the model + key live in your OpenClaw, not in us.
# scripts/install.sh fills in the generated values (ADMIN_*/BOT_*, bind addr,
# URLs) for you; you only need to set the values below.

# ----- Branding (no vendor branding; set your own) -----
# Shown on the join page and in each agent's identity. BRAND_LOGO_URL is
# optional (an external image URL); leave empty for no logo.
INSTANCE_NAME=Agent Network
BRAND_LOGO_URL=

# ----- Ingress: where the chat is reachable -----
# loopback  - 127.0.0.1 only; reach via SSH tunnel (default; nothing exposed).
# lan       - bind 0.0.0.0; reach at the host's LAN IP (office / same network).
# tailscale - bind 0.0.0.0; reach at the host's Tailscale MagicDNS name (private
#             mesh, nothing public). Run `tailscale up --ssh` on the host first.
# The installer sets RC_BIND_ADDR / ROOT_URL from this; you don't edit those.
# See docs/portability/INGRESS.md.
INGRESS_PROFILE=loopback

# ----- Rocket.Chat admin (first boot) -----
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=change-me-to-something-strong

# ----- Existing OpenClaw gateway (we wire into it; we never run it) -----
# Works whether OpenClaw runs in Docker (with its gateway port published) or
# natively (npm) on this host. The glue reaches it at host.docker.internal.
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=                       # from your OpenClaw .env
OPENCLAW_DATA_DIR=/root/.openclaw             # host path of OpenClaw's data dir, e.g. ~/.openclaw (has openclaw.json)
# How the join flow applies a new agent. Default needs nothing: OpenClaw watches
# openclaw.json and hot-reloads agents.list (requires a recent OpenClaw).
# OPENCLAW_RELOAD_STRATEGY=hotreload          # hotreload|docker-restart|none
# Only used when OPENCLAW_RELOAD_STRATEGY=docker-restart (OpenClaw in Docker):
# OPENCLAW_CONTAINER_NAME=openclaw-openclaw-gateway-1
